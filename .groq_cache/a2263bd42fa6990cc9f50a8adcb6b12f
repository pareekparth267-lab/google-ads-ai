{
  "fatigue_signals": [
    {
      "metric": "CTR (Click-Through Rate)",
      "threshold": 0.02,
      "action": "Pause Ad"
    },
    {
      "metric": "Conversion Rate",
      "threshold": 0.005,
      "action": "Pause Ad"
    },
    {
      "metric": "CPM (Cost Per Mille)",
      "threshold": 50,
      "action": "Adjust Budget"
    },
    {
      "metric": "Average Position",
      "threshold": 3,
      "action": "Adjust Bidding"
    }
  ],
  "creative_rotation_strategy": "Random Rotation with Weighted Probability",
  "refresh_schedule": {
    "display_ads_days": 14,
    "rsa_headlines_days": 7,
    "video_ads_days": 30
  },
  "creative_library_requirements": {
    "min_active_variations": 5,
    "variety_guidelines": [
      {
        "type": "Headline",
        "min_variations": 3,
        "max_variations": 5
      },
      {
        "type": "Description",
        "min_variations": 2,
        "max_variations": 4
      },
      {
        "type": "Image",
        "min_variations": 2,
        "max_variations": 4
      }
    ]
  },
  "automated_pause_rules": [
    {
      "condition": "Ad has been running for 30 days without a 10% increase in CTR",
      "action": "Pause Ad"
    },
    {
      "condition": "Ad has been running for 60 days without a 5% increase in Conversion Rate",
      "action": "Pause Ad"
    }
  ],
  "winner_promotion_criteria": [
    {
      "metric": "CTR",
      "weight": 0.5
    },
    {
      "metric": "Conversion Rate",
      "weight": 0.3
    },
    {
      "metric": "CPM",
      "weight": 0.2
    }
  ]
