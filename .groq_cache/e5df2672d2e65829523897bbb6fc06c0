      "trigger": "Daily",
      "description": "Alert if QS drops below threshold",
      "code": "function main() {\n  var threshold = 5;\n  var lowQSKeywords = AdsApp.keywords().withCondition('QualityScore < ' + threshold).get();\n  if (lowQSKeywords.totalNumEntities() > 0) {\n    var subject = 'Low Quality Score Keywords Found';\n    var body = 'The following keywords have a low quality score: ';\n    while (lowQSKeywords.hasNext()) {\n      var keyword = lowQSKeywords.next();\n      body += keyword.getText() + ', ';\n    }\n    MailApp.sendEmail('your_email@example.com', subject, body);\n  }\n}"
    },
    {
