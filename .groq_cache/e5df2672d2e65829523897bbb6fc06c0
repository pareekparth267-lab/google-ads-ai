    {
      "name": "Budget Pacer",
      "trigger": "Hourly",
      "description": "Pause campaigns if daily budget pacing is off",
      "code": "function main() {\n  var campaigns = AdsApp.campaigns().get();\n  while (campaigns.hasNext()) {\n    var campaign = campaigns.next();\n    var budget = campaign.getBudget();\n    var cost = campaign.getStatsFor('TODAY').getCost();\n    var pacing = cost / budget.getAmount();\n    if (pacing > 1.2 || pacing < 0.8) {\n      campaign.pause();\n      Logger.log('Campaign ' + campaign.getName() + ' paused due to pacing issue.');\n    }\n  }\n}"
    },
    {
